---
import { assets, nav, site } from "../data/site";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  robots?: string;
}

const { title, description, canonical = Astro.url.pathname, image = assets.logoLight, robots = "index, follow" } = Astro.props;
const canonicalUrl = new URL(canonical, site.url).toString();
const imageUrl = new URL(image, site.url).toString();
const currentPath = Astro.url.pathname.endsWith("/") ? Astro.url.pathname : `${Astro.url.pathname}/`;
---
<!doctype html>
<html lang="fr-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={robots} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_CA" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LegalService",
      name: site.legalName,
      url: site.url,
      telephone: site.phone,
      faxNumber: site.fax,
      email: site.email,
      image: imageUrl,
      address: {
        "@type": "PostalAddress",
        streetAddress: site.address.street,
        addressLocality: site.address.city,
        addressRegion: site.address.region,
        postalCode: site.address.postalCode,
        addressCountry: "CA"
      },
      areaServed: ["Montréal", "Grand Montréal", "Québec"],
      priceRange: "$$"
    })}></script>
  </head>
  <body>
    <a class="skip-link" href="#contenu">Aller au contenu</a>
    <header class="site-header">
      <div class="header-main">
        <a class="brand" href="/" aria-label="Accueil Valade et associés">
          <img src={assets.logoLight} alt="Valade et associés" width="442" height="100" />
        </a>
        <nav class="nav" aria-label="Navigation principale">
          {nav.map((item) => (
            <a class:list={{ "is-active": currentPath === item.href }} aria-current={currentPath === item.href ? "page" : undefined} href={item.href}>
              {item.label}
            </a>
          ))}
          <a class="platform-link" href={site.juriweb} target="_blank" rel="noopener noreferrer" aria-label="Ouvrir la plateforme Juriweb dans un nouvel onglet">
            Juriweb
          </a>
        </nav>
      </div>
    </header>
    <main id="contenu">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <div>
          <img class="footer-logo" src={assets.logoLight} alt="Valade et associés" />
          <p>Huissiers de justice du Grand Montréal au service des cabinets d’avocats, propriétaires, particuliers, notaires, contentieux et organisations québécoises depuis 1989.</p>
        </div>
        <div>
          <h2>Pour nous joindre</h2>
          <p><strong>{site.legalName}</strong><br />{site.address.street}<br />{site.address.city} ({site.address.region}) {site.address.postalCode}</p>
          <p><a href={`mailto:${site.email}`}>{site.email}</a><br /><a href="tel:+15148422345">Tél: {site.phone}</a><br />Fax: {site.fax}</p>
        </div>
        <div>
          <h2>Navigation</h2>
          <ul class="footer-links">
            {nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
            <li><a href="/blogue/">Blogue</a></li>
          </ul>
        </div>
      </div>
      <p class="copyright">© 2026 {site.legalName}. Tous droits réservés.</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --ink: #202638;
    --muted: #667085;
    --line: #dfe4ec;
    --paper: #f4f6f8;
    --white: #ffffff;
    --navy: #17285b;
    --blue: #243c7b;
    --pale-blue: #e7f2f6;
    --cyan: #9fd2df;
    --gold: #c9a44f;
    --danger: #9e2f2f;
    --shadow: 0 18px 44px rgba(18, 32, 65, 0.12);
    font-family: Arial, Helvetica, sans-serif;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; color: var(--ink); background: var(--white); line-height: 1.62; }
  img { max-width: 100%; display: block; }
  a { color: var(--blue); }
  .skip-link { position: absolute; left: -999px; top: 8px; z-index: 100; background: var(--navy); color: #fff; padding: 8px 12px; }
  .skip-link:focus { left: 8px; }

  .site-header { position: sticky; top: 0; z-index: 20; background: rgba(255,255,255,.96); border-bottom: 1px solid var(--line); box-shadow: 0 6px 28px rgba(18,32,65,.06); backdrop-filter: blur(12px); }
  .header-main { display: flex; align-items: center; justify-content: space-between; gap: 24px; padding: 14px clamp(18px, 4vw, 56px); }
  .brand img { width: 265px; height: auto; }
  .nav { display: flex; align-items: center; justify-content: flex-end; flex-wrap: wrap; gap: 2px; }
  .nav a { display: inline-flex; align-items: center; min-height: 40px; padding: 8px 10px; text-decoration: none; color: #30384a; font-size: 13px; font-weight: 700; text-transform: uppercase; border-radius: 4px; }
  .nav a:hover { background: var(--pale-blue); color: var(--blue); }
  .nav a.is-active { background: var(--blue); color: #fff; }
  .nav a.platform-link {
    gap: 6px;
    margin-left: 8px;
    padding-inline: 14px;
    border: 1px solid rgba(36, 60, 123, .22);
    background: #eef3ff;
    color: var(--blue);
    box-shadow: inset 0 0 0 1px rgba(255,255,255,.6);
  }
  .nav a.platform-link:hover {
    background: var(--blue);
    color: #fff;
  }

  .section { padding: clamp(54px, 8vw, 94px) clamp(18px, 4vw, 56px); }
  .section.alt { background: var(--paper); }
  .wrap { max-width: 1160px; margin: 0 auto; }
  .narrow { max-width: 850px; }
  .eyebrow { margin: 0 0 10px; color: var(--blue); font-size: 13px; font-weight: 800; text-transform: uppercase; letter-spacing: 0; }
  h1, h2, h3 { margin: 0 0 18px; line-height: 1.12; color: var(--navy); letter-spacing: 0; }
  h1 { font-size: clamp(38px, 6.4vw, 72px); max-width: 980px; }
  h2 { font-size: clamp(28px, 4vw, 46px); }
  h3 { font-size: 22px; }
  p { margin: 0 0 16px; }
  .lead { color: var(--muted); font-size: clamp(18px, 2vw, 22px); max-width: 820px; }
  .mission-intro { background: #fff; }
  .mission-intro .narrow { max-width: 930px; }
  .mission-intro h2 {
    max-width: 880px;
    margin: 0 auto 38px;
    color: #454545;
    font-size: clamp(26px, 3vw, 34px);
    line-height: 1.08;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 4px;
  }
  .mission-copy {
    color: #454545;
    font-size: 18px;
    line-height: 1.5;
  }
  .mission-copy p { margin-bottom: 22px; }
  .mission-copy a {
    color: var(--blue);
    font-weight: 800;
    text-decoration: none;
  }
  .mission-copy a:hover { color: var(--gold); }

  .hero { min-height: 670px; display: grid; align-items: center; color: #fff; background: linear-gradient(90deg, rgba(15,28,67,.88), rgba(23,40,91,.62), rgba(23,40,91,.22)), var(--hero-image) center/cover; padding: clamp(72px, 10vw, 130px) clamp(18px, 4vw, 56px); }
  .hero h1, .hero .eyebrow { color: #fff; }
  .hero .lead { color: rgba(255,255,255,.88); }
  .hero-content { max-width: 1160px; margin: 0 auto; width: 100%; }
  .hero-cardline { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 1px; margin-top: 46px; max-width: 930px; background: rgba(255,255,255,.2); border: 1px solid rgba(255,255,255,.22); }
  .hero-cardline div { padding: 22px; background: rgba(8,17,43,.42); }
  .hero-cardline strong { display: block; font-size: 38px; line-height: 1; color: #fff; }
  .hero-cardline span { color: rgba(255,255,255,.82); text-transform: uppercase; font-size: 12px; font-weight: 700; }

  .page-hero {
    min-height: 520px;
    display: grid;
    align-items: center;
    background:
      linear-gradient(90deg, rgba(245, 247, 250, .96) 0%, rgba(245, 247, 250, .9) 42%, rgba(245, 247, 250, .64) 72%, rgba(245, 247, 250, .34) 100%),
      var(--page-hero-image) center / cover no-repeat;
  }

  .page-hero .wrap {
    width: 100%;
  }

  .page-hero .lead {
    max-width: 760px;
  }

  .actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 28px; }
  .button { display: inline-flex; justify-content: center; align-items: center; min-height: 46px; padding: 12px 18px; border-radius: 4px; border: 1px solid transparent; background: var(--blue); color: #fff; font-weight: 800; text-decoration: none; text-transform: uppercase; font-size: 13px; }
  .button.gold { background: var(--gold); color: #14110a; }
  .button.outline { background: transparent; color: inherit; border-color: currentColor; }

  .grid { display: grid; gap: 22px; }
  .grid.two { grid-template-columns: repeat(2, minmax(0,1fr)); }
  .grid.three { grid-template-columns: repeat(3, minmax(0,1fr)); }
  .grid.four { grid-template-columns: repeat(4, minmax(0,1fr)); }
  .split { display: grid; grid-template-columns: .9fr 1.1fr; gap: clamp(30px, 6vw, 74px); align-items: start; }
  .card { background: #fff; border: 1px solid var(--line); border-radius: 6px; padding: 24px; box-shadow: 0 10px 26px rgba(18,32,65,.06); }
  .card.flush { padding: 0; overflow: hidden; }
  .notice { border-left: 4px solid var(--gold); background: #fff8e5; padding: 17px 18px; }
  .badge { display: inline-flex; align-items: center; min-height: 28px; padding: 4px 9px; border-radius: 4px; background: var(--pale-blue); color: var(--blue); font-weight: 800; font-size: 12px; text-transform: uppercase; }
  .media-card img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; }
  .media-card .card-body { padding: 22px; }

  .site-footer { background: #121a2c; color: rgba(255,255,255,.78); padding: 48px clamp(18px,4vw,56px) 26px; }
  .footer-inner { max-width: 1160px; margin: 0 auto; display: grid; grid-template-columns: 1.2fr 1fr .8fr; gap: 34px; }
  .footer-logo { width: 250px; margin-bottom: 18px; }
  .site-footer h2 { color: #fff; font-size: 18px; }
  .site-footer a { color: #fff; }
  .footer-links { list-style: none; padding: 0; margin: 0; }
  .footer-links li { margin-bottom: 8px; }
  .copyright { max-width: 1160px; margin: 30px auto 0; padding-top: 20px; border-top: 1px solid rgba(255,255,255,.16); font-size: 13px; color: rgba(255,255,255,.58); }

  @media (max-width: 940px) {
    .site-header { position: static; }
    .header-main { flex-direction: column; align-items: flex-start; }
    .nav { justify-content: flex-start; }
    .grid.two, .grid.three, .grid.four, .split, .footer-inner, .hero-cardline { grid-template-columns: 1fr; }
    .hero { min-height: 620px; }
  }

  @media (max-width: 720px) {
    .page-hero {
      min-height: 460px;
      background:
        linear-gradient(rgba(245, 247, 250, .94), rgba(245, 247, 250, .88)),
        var(--page-hero-image) center / cover no-repeat;
    }
  }
</style>
