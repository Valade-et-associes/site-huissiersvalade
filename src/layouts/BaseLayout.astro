---
import { assets, nav, site } from "../data/site";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  robots?: string;
}

const { title, description, canonical = Astro.url.pathname, image = assets.logoLight, robots = "index, follow" } = Astro.props;
const canonicalUrl = new URL(canonical, site.url).toString();
const imageUrl = new URL(image, site.url).toString();
const currentPath = Astro.url.pathname.endsWith("/") ? Astro.url.pathname : `${Astro.url.pathname}/`;
---
<!doctype html>
<html lang="fr-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={robots} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_CA" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LegalService",
      name: site.legalName,
      url: site.url,
      telephone: site.phone,
      faxNumber: site.fax,
      email: site.email,
      image: imageUrl,
      address: {
        "@type": "PostalAddress",
        streetAddress: site.address.street,
        addressLocality: site.address.city,
        addressRegion: site.address.region,
        postalCode: site.address.postalCode,
        addressCountry: "CA"
      },
      areaServed: ["Montréal", "Grand Montréal", "Québec"],
      priceRange: "$$"
    })}></script>
  </head>
  <body>
    <a class="skip-link" href="#contenu">Aller au contenu</a>
    <header class="site-header">
      <div class="header-main">
        <a class="brand" href="/" aria-label="Accueil Valade et associés">
          <img src={assets.logoLight} alt="Valade et associés" width="442" height="100" />
        </a>
        <nav class="nav" aria-label="Navigation principale">
          {nav.map((item) => (
            <a class:list={{ "is-active": currentPath === item.href }} aria-current={currentPath === item.href ? "page" : undefined} href={item.href}>
              {item.label}
            </a>
          ))}
        </nav>
        <a class="header-action" href={site.juriweb} target="_blank" rel="noopener noreferrer">Juriweb</a>
      </div>
    </header>
    <main id="contenu">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-about">
          <img class="footer-logo" src={assets.logoLight} alt="Valade et associés" />
          <p>Huissiers de justice à Montréal pour les cabinets d'avocats, propriétaires, particuliers, notaires, contentieux et organisations québécoises.</p>
        </div>
        <div class="footer-contact">
          <h2>Coordonnées</h2>
          <p><strong>{site.legalName}</strong><br />{site.address.street}<br />{site.address.city} ({site.address.region}) {site.address.postalCode}</p>
          <p><a href={`mailto:${site.email}`}>{site.email}</a><br /><a href="tel:+15148422345">{site.phone}</a><br />Fax: {site.fax}</p>
        </div>
        <div>
          <h2>Accès rapide</h2>
          <ul class="footer-links">
            {nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
            <li><a href={site.juriweb}>Juriweb</a></li>
          </ul>
        </div>
      </div>
      <p class="copyright">© 2026 {site.legalName}. Tous droits réservés.</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --ink: #17201f;
    --charcoal: #35413f;
    --muted: #687673;
    --line: #dce4df;
    --paper: #f4f7f5;
    --white: #ffffff;
    --forest: #163e34;
    --teal: #2f746d;
    --mist: #deece8;
    --sky: #dfeaf0;
    --clay: #b96346;
    --gold: #d6a847;
    --gold-soft: #fff7df;
    --danger: #a13932;
    --shadow: 0 28px 70px rgba(23, 32, 31, .14);
    --shadow-soft: 0 14px 34px rgba(23, 32, 31, .08);
    --radius: 8px;
    font-family: "Aptos", "Segoe UI", Arial, Helvetica, sans-serif;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    color: var(--ink);
    background:
      linear-gradient(90deg, rgba(22, 62, 52, .045) 1px, transparent 1px),
      linear-gradient(180deg, #fbfcfa 0%, #f4f7f5 100%);
    background-size: 96px 96px, auto;
    line-height: 1.62;
  }
  img { display: block; max-width: 100%; }
  a { color: var(--forest); text-underline-offset: 4px; }
  a:hover { color: var(--clay); }
  input, select, textarea, button { font: inherit; }

  .skip-link {
    position: absolute;
    left: -999px;
    top: 10px;
    z-index: 100;
    background: var(--forest);
    color: #fff;
    padding: 9px 12px;
  }
  .skip-link:focus { left: 10px; }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    border-bottom: 1px solid rgba(220, 228, 223, .9);
    background: rgba(251, 252, 250, .93);
    backdrop-filter: blur(18px);
  }
  .header-main {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(18px, 3vw, 38px);
    max-width: 1320px;
    margin: 0 auto;
    padding: 16px clamp(18px, 4vw, 56px);
  }
  .brand { display: inline-flex; align-items: center; }
  .brand img {
    width: clamp(210px, 22vw, 282px);
    height: auto;
    filter: saturate(.92) contrast(1.05);
  }
  .nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2px;
    min-width: 0;
  }
  .nav a,
  .header-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 9px 12px;
    color: var(--charcoal);
    font-size: 12px;
    font-weight: 850;
    letter-spacing: 0;
    text-decoration: none;
    text-transform: uppercase;
    border-radius: 6px;
    white-space: nowrap;
  }
  .nav a:hover,
  .nav a.is-active {
    background: var(--mist);
    color: var(--forest);
  }
  .header-action {
    border: 1px solid var(--forest);
    color: var(--forest);
  }
  .header-action:hover {
    background: var(--forest);
    color: #fff;
  }

  .section { padding: clamp(62px, 8vw, 112px) clamp(18px, 4vw, 56px); }
  .section.compact { padding-block: clamp(42px, 6vw, 72px); }
  .section.alt { background: linear-gradient(180deg, rgba(222, 236, 232, .56) 0%, rgba(244, 247, 245, .9) 100%); }
  .wrap { max-width: 1180px; margin: 0 auto; }
  .narrow { max-width: 880px; }
  .section-heading { max-width: 820px; margin-bottom: clamp(28px, 5vw, 54px); }
  .section-heading p:last-child { color: var(--muted); font-size: 18px; }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 14px;
    color: var(--clay);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }
  .eyebrow::before {
    content: "";
    width: 36px;
    height: 1px;
    background: currentColor;
  }
  h1, h2, h3 {
    margin: 0 0 18px;
    color: var(--ink);
    line-height: 1.04;
    letter-spacing: 0;
  }
  h1 {
    max-width: 1060px;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(42px, 7vw, 92px);
    font-weight: 500;
  }
  h2 {
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(31px, 4.5vw, 58px);
    font-weight: 500;
  }
  h3 { font-size: clamp(20px, 2vw, 25px); }
  p { margin: 0 0 16px; }
  .lead {
    max-width: 820px;
    color: var(--charcoal);
    font-size: clamp(18px, 2vw, 23px);
    line-height: 1.48;
  }

  .hero {
    position: relative;
    display: grid;
    align-items: end;
    min-height: min(780px, calc(100svh - 74px));
    overflow: hidden;
    padding: clamp(84px, 11vw, 154px) clamp(18px, 4vw, 56px) clamp(42px, 6vw, 78px);
    color: #fff;
    background-color: var(--forest);
    background-image:
      linear-gradient(90deg, rgba(10, 26, 23, .91) 0%, rgba(18, 47, 40, .72) 44%, rgba(18, 47, 40, .22) 76%, rgba(18, 47, 40, .04) 100%),
      var(--hero-image);
    background-position: center, center;
    background-size: cover, cover;
  }
  .hero::after {
    content: "";
    position: absolute;
    left: clamp(18px, 4vw, 56px);
    right: clamp(18px, 4vw, 56px);
    bottom: 0;
    height: 9px;
    background: linear-gradient(90deg, var(--clay), var(--gold), var(--teal));
  }
  .hero-content { position: relative; z-index: 1; width: 100%; max-width: 1180px; margin: 0 auto; }
  .hero h1, .hero .eyebrow { color: #fff; }
  .hero .lead { color: rgba(255, 255, 255, .87); }
  .hero-cardline {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    max-width: 920px;
    margin-top: clamp(34px, 5vw, 58px);
    background: rgba(255,255,255,.22);
  }
  .hero-cardline div {
    min-height: 132px;
    padding: 22px 24px;
    background: rgba(9, 24, 22, .5);
  }
  .hero-cardline strong {
    display: block;
    color: #fff;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(38px, 5vw, 64px);
    font-weight: 500;
    line-height: .95;
  }
  .hero-cardline span {
    display: block;
    margin-top: 10px;
    color: rgba(255,255,255,.82);
    font-size: 12px;
    font-weight: 850;
    text-transform: uppercase;
  }

  .page-hero {
    position: relative;
    min-height: 560px;
    display: grid;
    align-items: end;
    overflow: hidden;
    color: #fff;
    background-color: var(--forest);
    background-image:
      linear-gradient(90deg, rgba(9, 24, 22, .88) 0%, rgba(15, 49, 41, .72) 48%, rgba(15, 49, 41, .16) 100%),
      var(--page-hero-image);
    background-position: center, center;
    background-size: cover, cover;
    padding-bottom: clamp(56px, 8vw, 92px);
  }
  .page-hero .wrap { width: 100%; }
  .page-hero h1, .page-hero .eyebrow { color: #fff; }
  .page-hero .lead { color: rgba(255,255,255,.84); }

  .actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 30px; }
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 12px 18px;
    border: 1px solid transparent;
    border-radius: 6px;
    background: var(--forest);
    color: #fff;
    font-size: 12px;
    font-weight: 900;
    text-decoration: none;
    text-transform: uppercase;
    transition: transform .18s ease, box-shadow .18s ease, background .18s ease;
  }
  .button:hover { transform: translateY(-2px); background: var(--teal); color: #fff; box-shadow: var(--shadow-soft); }
  .button.gold { background: var(--clay); color: #fff; }
  .button.gold:hover { background: #9f5139; }
  .button.outline { background: transparent; color: inherit; border-color: currentColor; box-shadow: none; }
  .button.outline:hover { background: rgba(255,255,255,.12); }

  .grid { display: grid; gap: 22px; }
  .grid.two { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .grid.three { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .grid.four { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  .split {
    display: grid;
    grid-template-columns: minmax(260px, .92fr) minmax(0, 1.08fr);
    gap: clamp(32px, 6vw, 86px);
    align-items: start;
  }
  .card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
    box-shadow: var(--shadow-soft);
  }
  .card.flush { padding: 0; overflow: hidden; }
  .notice {
    border-left: 5px solid var(--clay);
    border-radius: 0 var(--radius) var(--radius) 0;
    background: var(--gold-soft);
    padding: 22px 24px;
    color: var(--charcoal);
  }
  .badge {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 4px 9px;
    border-radius: 4px;
    background: var(--mist);
    color: var(--forest);
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
  }
  .media-card img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; }
  .media-card .card-body { padding: 22px; }
  .content-panel {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding-block: clamp(28px, 4vw, 46px);
  }
  .feature-list {
    display: grid;
    gap: 11px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .feature-list li {
    position: relative;
    padding-left: 23px;
    color: var(--charcoal);
  }
  .feature-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: .72em;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--clay);
  }

  article.wrap.narrow {
    color: var(--charcoal);
    font-size: clamp(17px, 1.4vw, 19px);
  }
  article.wrap.narrow h2 {
    margin-top: clamp(34px, 5vw, 54px);
    padding-top: 22px;
    border-top: 1px solid var(--line);
  }
  article.wrap.narrow > img.card {
    width: 100%;
    margin-bottom: clamp(28px, 5vw, 48px);
    padding: 0;
    border-radius: var(--radius);
    object-fit: cover;
    aspect-ratio: 16 / 9;
  }

  .admin-form,
  .contact-form,
  .offer-form { color: var(--ink); }

  .admin-form input,
  .admin-form select,
  .admin-form textarea,
  .contact-form input,
  .contact-form textarea,
  .offer-form input,
  .offer-form select,
  .offer-form textarea {
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 13px 14px;
    background: #fff;
    color: var(--ink);
  }

  .site-footer {
    background: #101816;
    color: rgba(255,255,255,.74);
    padding: 64px clamp(18px,4vw,56px) 28px;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(260px, .9fr) minmax(190px, .55fr);
    gap: clamp(32px, 6vw, 72px);
    max-width: 1180px;
    margin: 0 auto;
  }
  .footer-logo {
    width: min(300px, 100%);
    margin-bottom: 22px;
    filter: brightness(1.22);
  }
  .footer-about p { max-width: 540px; font-size: 18px; }
  .site-footer h2 { color: #fff; font-size: 18px; font-family: inherit; font-weight: 850; }
  .site-footer a { color: #fff; }
  .footer-links { list-style: none; padding: 0; margin: 0; }
  .footer-links li { margin-bottom: 8px; }
  .copyright {
    max-width: 1180px;
    margin: 42px auto 0;
    padding-top: 22px;
    border-top: 1px solid rgba(255,255,255,.14);
    color: rgba(255,255,255,.55);
    font-size: 13px;
  }

  @media (max-width: 1080px) {
    .site-header { position: static; }
    .header-main { grid-template-columns: 1fr auto; }
    .brand { grid-column: 1; }
    .header-action { grid-column: 2; grid-row: 1; }
    .nav {
      grid-column: 1 / -1;
      justify-content: flex-start;
      overflow-x: auto;
      padding-bottom: 4px;
    }
    .nav a { flex: 0 0 auto; }
    .grid.two, .grid.three, .grid.four, .split, .footer-inner, .hero-cardline { grid-template-columns: 1fr; }
    .hero { min-height: 680px; }
  }

  @media (max-width: 720px) {
    body { background-size: 56px 56px, auto; }
    .header-main { padding-block: 12px; gap: 10px; }
    .brand img { width: min(220px, 64vw); }
    .header-action { min-height: 38px; padding-inline: 10px; }
    .hero { min-height: 640px; }
    .page-hero { min-height: 500px; }
    .actions .button { width: 100%; }
    .hero-cardline div { min-height: auto; }
  }
</style>
