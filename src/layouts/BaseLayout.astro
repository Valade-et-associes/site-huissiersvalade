---
import { assets, nav, site } from "../data/site";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  robots?: string;
}

const { title, description, canonical = Astro.url.pathname, image = assets.logoLight, robots = "index, follow" } = Astro.props;
const canonicalUrl = new URL(canonical, site.url).toString();
const imageUrl = new URL(image, site.url).toString();
const currentPath = Astro.url.pathname.endsWith("/") ? Astro.url.pathname : `${Astro.url.pathname}/`;
---
<!doctype html>
<html lang="fr-CA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={robots} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_CA" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LegalService",
      name: site.legalName,
      url: site.url,
      telephone: site.phone,
      faxNumber: site.fax,
      email: site.email,
      image: imageUrl,
      address: {
        "@type": "PostalAddress",
        streetAddress: site.address.street,
        addressLocality: site.address.city,
        addressRegion: site.address.region,
        postalCode: site.address.postalCode,
        addressCountry: "CA"
      },
      areaServed: ["Montréal", "Grand Montréal", "Québec"],
      priceRange: "$$"
    })}></script>
  </head>
  <body>
    <a class="skip-link" href="#contenu">Aller au contenu</a>
    <header class="site-header">
      <div class="header-strip">
        <a href={`mailto:${site.email}`}>{site.email}</a>
        <span>{site.hours}</span>
        <a href="tel:+15148422345">{site.phone}</a>
      </div>
      <div class="header-main">
        <a class="brand" href="/" aria-label="Accueil Valade et associés">
          <img src={assets.logoLight} alt="Valade et associés" width="442" height="100" />
        </a>
        <nav class="nav" aria-label="Navigation principale">
          {nav.map((item) => (
            <a class:list={{ "is-active": currentPath === item.href }} aria-current={currentPath === item.href ? "page" : undefined} href={item.href}>
              {item.label}
            </a>
          ))}
          <a class="platform-link" href={site.juriweb} target="_blank" rel="noopener noreferrer" aria-label="Ouvrir la plateforme Juriweb dans un nouvel onglet">
            Juriweb
          </a>
        </nav>
      </div>
    </header>
    <main id="contenu">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-about">
          <img class="footer-logo" src={assets.logoLight} alt="Valade et associés" />
          <p>Huissiers de justice du Grand Montréal au service des cabinets d’avocats, propriétaires, particuliers, notaires, contentieux et organisations québécoises depuis 1989.</p>
        </div>
        <div>
          <h2>Pour nous joindre</h2>
          <p><strong>{site.legalName}</strong><br />{site.address.street}<br />{site.address.city} ({site.address.region}) {site.address.postalCode}</p>
          <p><a href={`mailto:${site.email}`}>{site.email}</a><br /><a href="tel:+15148422345">Tél: {site.phone}</a><br />Fax: {site.fax}</p>
        </div>
        <div>
          <h2>Navigation</h2>
          <ul class="footer-links">
            {nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
            <li><a href="/blogue/">Blogue</a></li>
          </ul>
        </div>
      </div>
      <p class="copyright">© 2026 {site.legalName}. Tous droits réservés.</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --ink: #202638;
    --charcoal: #3f4654;
    --muted: #667085;
    --line: #dfe4ec;
    --paper: #f4f6f8;
    --white: #ffffff;
    --navy: #17285b;
    --blue: #243c7b;
    --soft-blue: #eef4fb;
    --pale-blue: #e7f2f6;
    --cyan: #9fd2df;
    --gold: #c9a44f;
    --gold-soft: #fff6dc;
    --danger: #9e2f2f;
    --shadow: 0 22px 60px rgba(18, 32, 65, 0.13);
    --shadow-soft: 0 12px 34px rgba(18, 32, 65, 0.08);
    --radius: 6px;
    font-family: Arial, Helvetica, sans-serif;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    color: var(--ink);
    background:
      linear-gradient(90deg, rgba(23, 40, 91, .035) 1px, transparent 1px),
      linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    background-size: 64px 64px, auto;
    line-height: 1.62;
  }
  img { max-width: 100%; display: block; }
  a { color: var(--blue); text-underline-offset: 3px; }
  a:hover { color: var(--navy); }
  .skip-link { position: absolute; left: -999px; top: 8px; z-index: 100; background: var(--navy); color: #fff; padding: 8px 12px; }
  .skip-link:focus { left: 8px; }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid rgba(223, 228, 236, .86);
    background: rgba(255,255,255,.97);
    box-shadow: 0 8px 28px rgba(18,32,65,.07);
    backdrop-filter: blur(14px);
  }
  .header-strip {
    display: flex;
    justify-content: flex-end;
    gap: 18px;
    padding: 7px clamp(18px, 4vw, 56px);
    background: var(--navy);
    color: rgba(255,255,255,.78);
    font-size: 12px;
    font-weight: 700;
  }
  .header-strip a { color: #fff; text-decoration: none; }
  .header-main { display: flex; align-items: center; justify-content: space-between; gap: 24px; padding: 13px clamp(18px, 4vw, 56px); }
  .brand { display: inline-flex; flex: 0 0 auto; }
  .brand img { width: clamp(210px, 23vw, 285px); height: auto; }
  .nav { display: flex; align-items: center; justify-content: flex-end; flex-wrap: wrap; gap: 5px; }
  .nav a {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    padding: 8px 10px;
    border-bottom: 2px solid transparent;
    color: #30384a;
    font-size: 12px;
    font-weight: 800;
    text-decoration: none;
    text-transform: uppercase;
  }
  .nav a:hover { border-color: var(--gold); color: var(--blue); }
  .nav a.is-active { border-color: var(--blue); color: var(--blue); }
  .nav a.platform-link {
    margin-left: 8px;
    padding-inline: 14px;
    border: 1px solid rgba(36, 60, 123, .22);
    border-radius: var(--radius);
    background: var(--soft-blue);
    color: var(--blue);
  }
  .nav a.platform-link:hover { background: var(--blue); color: #fff; }

  .section { padding: clamp(58px, 8vw, 106px) clamp(18px, 4vw, 56px); }
  .section.compact { padding-block: clamp(42px, 6vw, 68px); }
  .section.alt { background: linear-gradient(180deg, var(--paper) 0%, #eef2f7 100%); }
  .wrap { max-width: 1180px; margin: 0 auto; }
  .narrow { max-width: 880px; }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin: 0 0 12px;
    color: var(--blue);
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0;
  }
  .eyebrow::before {
    content: "";
    width: 28px;
    height: 2px;
    background: var(--gold);
  }
  h1, h2, h3 { margin: 0 0 18px; line-height: 1.08; color: var(--navy); letter-spacing: 0; }
  h1 { font-size: clamp(38px, 6vw, 72px); max-width: 1020px; }
  h2 { font-size: clamp(28px, 4vw, 48px); }
  h3 { font-size: clamp(20px, 2vw, 24px); }
  p { margin: 0 0 16px; }
  .lead { color: var(--muted); font-size: clamp(18px, 2vw, 22px); max-width: 820px; }

  .hero {
    position: relative;
    min-height: min(760px, calc(100svh - 112px));
    display: grid;
    align-items: center;
    overflow: hidden;
    color: #fff;
    background-color: var(--navy);
    background-image:
      linear-gradient(90deg, rgba(12, 22, 54, .88) 0%, rgba(23, 40, 91, .58) 39%, rgba(23, 40, 91, .16) 68%, rgba(23, 40, 91, .02) 100%),
      var(--hero-image);
    background-position: center center, center center;
    background-size: cover, cover;
    background-repeat: no-repeat, no-repeat;
    padding: clamp(76px, 10vw, 138px) clamp(18px, 4vw, 56px) clamp(54px, 7vw, 86px);
  }
  .hero::after {
    content: "";
    position: absolute;
    right: clamp(18px, 6vw, 90px);
    bottom: clamp(18px, 4vw, 48px);
    width: clamp(160px, 20vw, 280px);
    height: 3px;
    background: linear-gradient(90deg, var(--gold), rgba(255,255,255,.18));
  }
  .hero h1, .hero .eyebrow { color: #fff; }
  .hero .eyebrow::before { background: var(--gold); }
  .hero .lead { color: rgba(255,255,255,.88); }
  .hero-content { position: relative; z-index: 1; max-width: 1180px; margin: 0 auto; width: 100%; }
  .hero-cardline {
    display: grid;
    grid-template-columns: repeat(3, minmax(0,1fr));
    gap: 0;
    margin-top: clamp(34px, 5vw, 56px);
    max-width: 920px;
    border-top: 1px solid rgba(255,255,255,.25);
    border-bottom: 1px solid rgba(255,255,255,.25);
  }
  .hero-cardline div { padding: 22px 24px 20px; border-right: 1px solid rgba(255,255,255,.2); background: rgba(5,12,32,.34); }
  .hero-cardline div:last-child { border-right: 0; }
  .hero-cardline strong { display: block; font-size: clamp(34px, 5vw, 56px); line-height: .95; color: #fff; }
  .hero-cardline span { color: rgba(255,255,255,.8); text-transform: uppercase; font-size: 12px; font-weight: 800; }

  .page-hero {
    min-height: 520px;
    display: grid;
    align-items: center;
    overflow: hidden;
    background:
      linear-gradient(90deg, rgba(244, 246, 248, .98) 0%, rgba(244, 246, 248, .9) 44%, rgba(244, 246, 248, .62) 74%, rgba(244, 246, 248, .32) 100%),
      var(--page-hero-image) center / cover no-repeat;
  }
  .page-hero .wrap { width: 100%; }
  .page-hero .lead { max-width: 760px; }

  .actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 28px; }
  .button {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    min-height: 48px;
    padding: 12px 18px;
    border-radius: var(--radius);
    border: 1px solid transparent;
    background: var(--blue);
    color: #fff;
    font-weight: 900;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 12px;
    transition: transform .18s ease, box-shadow .18s ease, background .18s ease;
  }
  .button:hover { transform: translateY(-2px); background: var(--navy); color: #fff; box-shadow: var(--shadow-soft); }
  .button.gold { background: var(--gold); color: #161100; }
  .button.gold:hover { background: #b58f35; color: #fff; }
  .button.outline { background: transparent; color: inherit; border-color: currentColor; box-shadow: none; }
  .button.outline:hover { background: rgba(255,255,255,.12); }

  .grid { display: grid; gap: 22px; }
  .grid.two { grid-template-columns: repeat(2, minmax(0,1fr)); }
  .grid.three { grid-template-columns: repeat(3, minmax(0,1fr)); }
  .grid.four { grid-template-columns: repeat(4, minmax(0,1fr)); }
  .split { display: grid; grid-template-columns: .92fr 1.08fr; gap: clamp(32px, 6vw, 82px); align-items: start; }
  .card {
    background: #fff;
    border: 1px solid rgba(223, 228, 236, .9);
    border-radius: var(--radius);
    padding: 24px;
    box-shadow: var(--shadow-soft);
  }
  .card.flush { padding: 0; overflow: hidden; }
  .notice {
    border-left: 4px solid var(--gold);
    border-radius: 0 var(--radius) var(--radius) 0;
    background: var(--gold-soft);
    padding: 18px 20px;
    color: var(--charcoal);
  }
  .badge { display: inline-flex; align-items: center; min-height: 28px; padding: 4px 9px; border-radius: 4px; background: var(--pale-blue); color: var(--blue); font-weight: 900; font-size: 12px; text-transform: uppercase; }
  .media-card img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; }
  .media-card .card-body { padding: 22px; }
  .content-panel {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding-block: clamp(28px, 4vw, 46px);
  }
  .feature-list {
    display: grid;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .feature-list li {
    position: relative;
    padding-left: 22px;
    color: var(--charcoal);
  }
  .feature-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: .72em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--gold);
  }

  article.wrap.narrow {
    color: var(--charcoal);
    font-size: clamp(17px, 1.4vw, 19px);
  }
  article.wrap.narrow h2 {
    margin-top: clamp(34px, 5vw, 54px);
    padding-top: 22px;
    border-top: 1px solid var(--line);
  }
  article.wrap.narrow > img.card {
    width: 100%;
    margin-bottom: clamp(28px, 5vw, 48px);
    padding: 0;
    border-radius: var(--radius);
    object-fit: cover;
    aspect-ratio: 16 / 9;
  }

  .admin-form,
  .contact-form,
  .offer-form {
    color: var(--ink);
  }

  .admin-form input,
  .admin-form select,
  .admin-form textarea {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 13px 14px;
    background: #fff;
  }

  .site-footer {
    background:
      linear-gradient(135deg, #111a2d 0%, #17285b 100%);
    color: rgba(255,255,255,.78);
    padding: 58px clamp(18px,4vw,56px) 26px;
  }
  .footer-inner { max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: 1.25fr 1fr .75fr; gap: 38px; }
  .footer-logo { width: 250px; margin-bottom: 18px; }
  .footer-about p { max-width: 520px; }
  .site-footer h2 { color: #fff; font-size: 18px; }
  .site-footer a { color: #fff; }
  .footer-links { list-style: none; padding: 0; margin: 0; }
  .footer-links li { margin-bottom: 8px; }
  .copyright { max-width: 1180px; margin: 34px auto 0; padding-top: 20px; border-top: 1px solid rgba(255,255,255,.16); font-size: 13px; color: rgba(255,255,255,.58); }

  input,
  select,
  textarea,
  button { font: inherit; }

  @media (max-width: 1040px) {
    .site-header { position: static; }
    .header-strip { justify-content: flex-start; flex-wrap: wrap; }
    .header-main { flex-direction: column; align-items: flex-start; }
    .nav { justify-content: flex-start; }
    .grid.two, .grid.three, .grid.four, .split, .footer-inner, .hero-cardline { grid-template-columns: 1fr; }
    .hero { min-height: 650px; }
  }

  @media (max-width: 720px) {
    body { background-size: 44px 44px, auto; }
    .header-strip { display: none; }
    .nav {
      width: 100%;
      overflow-x: auto;
      flex-wrap: nowrap;
      justify-content: flex-start;
      padding-bottom: 4px;
    }
    .nav a { flex: 0 0 auto; }
    .nav a.platform-link { margin-left: 0; }
    .hero { min-height: 620px; }
    .hero-cardline div { border-right: 0; border-bottom: 1px solid rgba(255,255,255,.2); }
    .hero-cardline div:last-child { border-bottom: 0; }
    .page-hero {
      min-height: 460px;
      background:
        linear-gradient(rgba(245, 247, 250, .94), rgba(245, 247, 250, .88)),
        var(--page-hero-image) center / cover no-repeat;
    }
    .actions .button { width: 100%; }
  }
</style>
