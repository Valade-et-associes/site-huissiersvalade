---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { assets } from "../../../data/site";
---
<BaseLayout title="Charles Valade - Valade et associés" description="Profil de Charles Valade, huissier de justice et vice-président, Développement des affaires.">
  <section class="section profile-section">
    <div class="wrap profile-layout">
      <img src={assets.charles} alt="Charles Valade" />
      <div>
        <p class="eyebrow">Vice-président, Développement des affaires</p>
        <h1>Charles Valade, huissier de justice #1094, B.Sc. Act.</h1>
        <p class="lead">Expertise en développement des affaires, relation clientèle, optimisation des processus, conformité, finances et gestion du risque.</p>
        <div class="actions">
          <a class="button" href="/a-propos/">Retour à l'équipe</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .profile-section {
    background: #101816;
    color: rgba(255,255,255,.78);
  }

  .profile-layout {
    display: grid;
    grid-template-columns: minmax(260px, .42fr) minmax(0, .58fr);
    gap: clamp(30px, 6vw, 82px);
    align-items: center;
  }

  .profile-layout img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--radius);
  }

  .profile-layout h1,
  .profile-layout .eyebrow {
    color: #fff;
  }

  .profile-layout .lead {
    color: rgba(255,255,255,.78);
  }

  @media (max-width: 760px) {
    .profile-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
