---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { assets } from "../../../data/site";
---
<BaseLayout title="Charles Valade - Valade et associés" description="Profil de Charles Valade, huissier de justice et vice-président, Développement des affaires.">
  <section class="section">
    <div class="wrap split">
      <img class="card" src={assets.charles} alt="Charles Valade" />
      <div>
        <p class="eyebrow">Vice-président, Développement des affaires</p>
        <h1>Charles Valade, huissier de justice #1094, B.Sc. Act.</h1>
        <p class="lead">Expertise en développement des affaires, relation avec la clientèle, optimisation des processus, conformité, finances et gestion du risque.</p>
      </div>
    </div>
  </section>
</BaseLayout>
