---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { assets, site } from "../../data/site";
---
<BaseLayout
  title="Contact - Valade et associés"
  description="Coordonnées de Valade et associés, huissiers de justice à Montréal: adresse, téléphone, télécopieur, courriel et heures d'ouverture."
>
  <section class="section page-hero" style={`--page-hero-image: url('${assets.contactHero}')`}>
    <div class="wrap narrow">
      <p class="eyebrow">Contact</p>
      <h1>Confier un mandat, demander un prix, joindre l'équipe.</h1>
      <p class="lead">Nous sommes disponibles du lundi au vendredi pour les demandes de signification, d'exécution, de constat et de services connexes.</p>
    </div>
  </section>

  <section class="section contact-section">
    <div class="wrap contact-layout">
      <aside class="contact-details">
        <p class="eyebrow">Coordonnées</p>
        <h2>{site.legalName}</h2>
        <dl>
          <div>
            <dt>Adresse</dt>
            <dd>{site.address.street}<br />{site.address.city}, QC {site.address.postalCode}</dd>
          </div>
          <div>
            <dt>Heures</dt>
            <dd>{site.hours}</dd>
          </div>
          <div>
            <dt>Téléphone</dt>
            <dd><a href="tel:+15148422345">{site.phone}</a><br /><a href="tel:+18888759499">{site.tollFree}</a></dd>
          </div>
          <div>
            <dt>Courriel</dt>
            <dd><a href={`mailto:${site.email}`}>{site.email}</a></dd>
          </div>
        </dl>
      </aside>

      <form class="contact-form" name="contact" method="POST" action="/contact/merci/" data-netlify="true" data-netlify-recaptcha="true" netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden-field">
          <label>Ne pas remplir ce champ: <input name="bot-field" /></label>
        </p>

        <div class="form-row">
          <label>
            <span>Votre nom</span>
            <input type="text" name="name" autocomplete="name" placeholder="Votre nom" required />
          </label>
          <label>
            <span>Votre courriel</span>
            <input type="email" name="email" autocomplete="email" placeholder="Votre courriel" required />
          </label>
        </div>

        <label>
          <span>Téléphone</span>
          <input type="tel" name="phone" autocomplete="tel" placeholder="Téléphone" />
        </label>

        <label>
          <span>Votre message</span>
          <textarea name="message" rows="7" placeholder="Votre message" required></textarea>
        </label>

        <div class="captcha" data-netlify-recaptcha="true"></div>
        <button type="submit">Envoyer le message</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: minmax(280px, .75fr) minmax(0, 1.25fr);
    gap: clamp(34px, 7vw, 92px);
    align-items: start;
  }

  .contact-details {
    position: sticky;
    top: 108px;
    padding-top: 8px;
  }

  .contact-details h2 {
    font-size: clamp(28px, 4vw, 44px);
  }

  .contact-details dl {
    display: grid;
    gap: 0;
    margin: 32px 0 0;
    border-top: 1px solid var(--line);
  }

  .contact-details dl div {
    padding: 18px 0;
    border-bottom: 1px solid var(--line);
  }

  .contact-details dt {
    margin-bottom: 5px;
    color: var(--clay);
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
  }

  .contact-details dd {
    margin: 0;
    color: var(--charcoal);
  }

  .contact-form {
    display: grid;
    gap: 14px;
    width: 100%;
    padding: clamp(22px, 4vw, 38px);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: #fff;
    box-shadow: var(--shadow);
  }

  .form-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .contact-form label {
    display: grid;
    gap: 7px;
    margin: 0;
  }

  .contact-form span {
    color: var(--charcoal);
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
  }

  .contact-form input,
  .contact-form textarea {
    width: 100%;
    background: var(--paper);
  }

  .contact-form textarea {
    min-height: 190px;
    resize: vertical;
  }

  .captcha {
    min-height: 64px;
    padding: 8px 0;
  }

  .contact-form button {
    min-height: 56px;
    border: 0;
    border-radius: 6px;
    background: var(--forest);
    color: #fff;
    font-weight: 900;
    text-transform: uppercase;
    cursor: pointer;
  }

  .contact-form button:hover {
    background: var(--teal);
  }

  .hidden-field {
    display: none;
  }

  @media (max-width: 940px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }

    .contact-details {
      position: static;
    }
  }

  @media (max-width: 720px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
