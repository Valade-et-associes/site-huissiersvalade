---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { assets, site } from "../../data/site";
---
<BaseLayout
  title="Contact - Valade et associés"
  description="Coordonnées de Valade et associés, huissiers de justice à Montréal: adresse, téléphone, télécopieur, courriel et heures d'ouverture."
>
  <section class="section page-hero" style={`--page-hero-image: url('${assets.contactHero}')`}>
    <div class="wrap narrow">
      <p class="eyebrow">Contact</p>
      <h1>Pour nous joindre</h1>
      <p class="lead">Notre équipe est disponible du lundi au vendredi, de 8 h 30 à 17 h, pour vos demandes de signification, d’exécution, de constat et de services connexes.</p>
    </div>
  </section>

  <section class="section contact-section">
    <div class="wrap contact-layout">
      <aside class="contact-details">
        <p class="eyebrow">Coordonnées</p>
        <h2>{site.legalName}</h2>
        <p>{site.address.street}<br />{site.address.city}, QC {site.address.postalCode}</p>
        <p>{site.hours}</p>
        <p>
          Tél. : <a href="tel:+15148422345">{site.phone}</a><br />
          Numéro sans frais : <a href="tel:+18888759499">{site.tollFree}</a><br />
          Fax : {site.fax}
        </p>
        <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
      </aside>

      <form class="contact-form" name="contact" method="POST" action="/contact/merci/" data-netlify="true" data-netlify-recaptcha="true" netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden-field">
          <label>Ne pas remplir ce champ: <input name="bot-field" /></label>
        </p>

        <div class="form-row">
          <label>
            <span>Votre nom</span>
            <input type="text" name="name" autocomplete="name" placeholder="Votre nom" required />
          </label>
          <label>
            <span>Votre courriel</span>
            <input type="email" name="email" autocomplete="email" placeholder="Votre courriel" required />
          </label>
        </div>

        <label>
          <span>Téléphone</span>
          <input type="tel" name="phone" autocomplete="tel" placeholder="Téléphone" />
        </label>

        <label>
          <span>Votre message</span>
          <textarea name="message" rows="6" placeholder="Votre message" required></textarea>
        </label>

        <div class="captcha" data-netlify-recaptcha="true"></div>
        <button type="submit">Envoyez votre message</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: minmax(260px, 340px) minmax(0, 760px);
    gap: clamp(34px, 7vw, 84px);
    align-items: start;
    justify-content: center;
  }

  .contact-details {
    padding: 26px;
    border-left: 4px solid var(--gold);
    background: var(--soft-blue);
    color: var(--charcoal);
    font-size: 17px;
    line-height: 1.55;
  }

  .contact-details h2 {
    font-size: clamp(25px, 3vw, 34px);
  }

  .contact-form {
    display: grid;
    gap: 0;
    width: 100%;
    max-width: 760px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: #fff;
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .form-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .contact-form label {
    display: grid;
    margin: 0;
  }

  .contact-form span {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
  }

  .contact-form input,
  .contact-form textarea {
    width: 100%;
    border: 0;
    border-bottom: 1px solid var(--line);
    border-radius: 0;
    padding: 17px 18px;
    background: #fff;
    color: var(--ink);
    font: inherit;
    letter-spacing: 0;
  }

  .form-row label + label input {
    border-left: 1px solid var(--line);
  }

  .contact-form input::placeholder,
  .contact-form textarea::placeholder {
    color: var(--muted);
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .contact-form textarea {
    min-height: 170px;
    resize: vertical;
  }

  .captcha {
    min-height: 64px;
    padding: 12px 18px;
    border-bottom: 1px solid var(--line);
  }

  .contact-form button {
    min-height: 58px;
    border: 0;
    background: var(--blue);
    color: #fff;
    font: inherit;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
  }

  .contact-form button:hover {
    background: var(--navy);
    color: #fff;
  }

  .hidden-field {
    display: none;
  }

  @media (max-width: 940px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }

    .contact-form {
      max-width: none;
    }
  }

  @media (max-width: 720px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    .form-row label + label input {
      border-left: 0;
    }
  }
</style>
