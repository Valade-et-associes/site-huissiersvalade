---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Message envoyé - Valade et associés"
  description="Confirmation d'envoi du formulaire de contact de Valade et associés."
  canonical="/contact/merci/"
>
  <section class="section">
    <div class="wrap narrow">
      <p class="eyebrow">Message envoyé</p>
      <h1>Merci pour votre message</h1>
      <p class="lead">Votre demande a bien été transmise. L'équipe de Valade et associés en prendra connaissance dans les meilleurs délais.</p>
      <div class="actions">
        <a class="button" href="/">Retour à l'accueil</a>
        <a class="button outline" href="/contact/">Retour au contact</a>
      </div>
    </div>
  </section>
</BaseLayout>
