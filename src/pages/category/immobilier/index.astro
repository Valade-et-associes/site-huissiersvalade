---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { posts } from "../../../data/site";

const immobilier = posts.filter((post) => post.category === "Immobilier");
---
<BaseLayout title="Immobilier - Valade et associés" description="Articles de Valade et associés dans la catégorie Immobilier.">
  <section class="section alt">
    <div class="wrap narrow">
      <p class="eyebrow">Catégorie</p>
      <h1>Immobilier</h1>
    </div>
  </section>
  <section class="section">
    <div class="wrap grid two">
      {immobilier.map((post) => <article class="card"><h2><a href={post.href}>{post.title}</a></h2><p>{post.excerpt}</p></article>)}
    </div>
  </section>
</BaseLayout>
