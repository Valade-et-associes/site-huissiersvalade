---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { assets, posts } from "../../data/site";
---
<BaseLayout
  title="Blogue - Valade et associés"
  description="Actualités et nouvelles de Valade et associés, huissiers de justice à Montréal."
>
  <section class="section page-hero" style={`--page-hero-image: url('${assets.heroDocument}')`}>
    <div class="wrap narrow">
      <p class="eyebrow">Blogue</p>
      <h1>Repères, nouvelles et contenus conservés.</h1>
      <p class="lead">Articles et pages d'information utiles, conservés pour préserver les contenus et les adresses existantes.</p>
    </div>
  </section>
  <section class="section">
    <div class="wrap post-grid">
      {posts.map((post) => (
        <article class="post-card">
          <img src={post.image} alt="" loading="lazy" />
          <div>
            <p><span class="badge">{post.category}</span> {post.date}</p>
            <h2><a href={post.href}>{post.title}</a></h2>
            <p>{post.excerpt}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .post-grid {
    display: grid;
    gap: 18px;
  }

  .post-card {
    display: grid;
    grid-template-columns: minmax(220px, .35fr) minmax(0, .65fr);
    gap: clamp(20px, 4vw, 38px);
    align-items: center;
    padding: 18px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: #fff;
    box-shadow: var(--shadow-soft);
  }

  .post-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 6px;
  }

  .post-card h2 {
    font-size: clamp(25px, 3vw, 38px);
  }

  .post-card p {
    color: var(--charcoal);
  }

  @media (max-width: 760px) {
    .post-card {
      grid-template-columns: 1fr;
    }
  }
</style>
