---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { assets, businessServices, tariffs } from "../../data/site";

const audiences = [
  {
    title: "Entreprises et professionnels",
    text: "Cabinets d'avocats, notaires, contentieux, propriétaires et organisations qui doivent faire signifier, exécuter ou documenter rapidement un dossier.",
    items: ["Délais suivis", "Documents structurés", "Coordination avec vos équipes"]
  },
  {
    title: "Particuliers",
    text: "Personnes qui ont besoin d'un huissier pour une mise en demeure, une décision, une exécution, un constat ou une situation locative.",
    items: ["Explications claires", "Démarches encadrées", "Prix validé avant l'intervention"]
  }
];
---
<BaseLayout
  title="Services et tarifs - Valade et associés"
  description="Services d'huissiers pour entreprises et particuliers: signification, exécution de jugement, constats, services connexes et tarification."
>
  <section class="section page-hero services-hero" style={`--page-hero-image: url('${assets.servicesHero}')`}>
    <div class="wrap narrow">
      <p class="eyebrow">Services et tarifs</p>
      <h1>Une intervention claire, du premier appel au procès-verbal.</h1>
      <p class="lead">Nos services couvrent la signification, l'exécution, les constats et les mandats connexes, pour les professionnels comme pour les particuliers.</p>
    </div>
  </section>

  <section class="section audience-section">
    <div class="wrap audience-grid">
      {audiences.map((audience) => (
        <article class="audience-panel">
          <h2>{audience.title}</h2>
          <p>{audience.text}</p>
          <ul class="feature-list">
            {audience.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section alt">
    <div class="wrap">
      <div class="section-heading">
        <p class="eyebrow">Services</p>
        <h2>Les mandats les plus fréquents</h2>
        <p>Chaque dossier commence par une validation du document, de l'adresse, du délai et des contraintes d'intervention.</p>
      </div>
      <div class="service-table">
        {businessServices.map((service, index) => (
          <article class="service-row">
            <span class="row-number">{String(index + 1).padStart(2, "0")}</span>
            <div>
              <h3>{service.title}</h3>
              <p>{service.text}</p>
            </div>
            <ul>
              {service.examples.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section tariff-section">
    <div class="wrap tariff-layout">
      <div>
        <p class="eyebrow">Tarification</p>
        <h2>Des honoraires encadrés, sans zone grise.</h2>
        <p>Les services professionnels des huissiers de justice sont encadrés par règlement. Pour certains services connexes, une tarification professionnelle peut aussi être convenue selon le mandat.</p>
      </div>
      <div class="tariff-downloads">
        {tariffs.map((tariff) => (
          <a class="tariff-card" href={tariff.href} download>
            <span class="tariff-title">
              <img src={assets.pdfIcon} alt="" loading="lazy" />
              <span>{tariff.title}</span>
            </span>
            <span class="tariff-action">Télécharger</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .audience-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    background: var(--line);
    box-shadow: var(--shadow-soft);
  }

  .audience-panel {
    min-height: 360px;
    padding: clamp(28px, 5vw, 52px);
    background: #fff;
  }

  .audience-panel h2 {
    max-width: 560px;
  }

  .audience-panel p {
    max-width: 620px;
    color: var(--muted);
    font-size: 18px;
  }

  .service-table {
    display: grid;
    border-top: 1px solid var(--line);
  }

  .service-row {
    display: grid;
    grid-template-columns: 72px minmax(220px, .72fr) minmax(0, 1fr);
    gap: clamp(18px, 4vw, 44px);
    padding: clamp(24px, 4vw, 38px) 0;
    border-bottom: 1px solid var(--line);
  }

  .row-number {
    color: var(--clay);
    font-weight: 900;
  }

  .service-row h3 {
    margin-bottom: 10px;
    font-size: clamp(24px, 3vw, 36px);
  }

  .service-row p {
    color: var(--muted);
  }

  .service-row ul {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px 18px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .service-row li {
    position: relative;
    padding-left: 20px;
    color: var(--charcoal);
  }

  .service-row li::before {
    content: "";
    position: absolute;
    left: 0;
    top: .7em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--teal);
  }

  .tariff-layout {
    display: grid;
    grid-template-columns: minmax(280px, .8fr) minmax(0, 1.2fr);
    gap: clamp(32px, 6vw, 82px);
  }

  .tariff-layout p:not(.eyebrow) {
    color: var(--charcoal);
    font-size: 18px;
  }

  .tariff-downloads {
    display: grid;
    gap: 14px;
  }

  .tariff-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: center;
    min-height: 112px;
    padding: 18px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: #fff;
    color: var(--ink);
    text-decoration: none;
    box-shadow: var(--shadow-soft);
  }

  .tariff-card:hover {
    transform: translateY(-2px);
  }

  .tariff-title {
    display: flex;
    align-items: center;
    gap: 16px;
    min-width: 0;
    font-weight: 850;
  }

  .tariff-title img {
    width: 62px;
    height: 62px;
    object-fit: contain;
    padding: 12px;
    border-radius: 6px;
    background: var(--mist);
  }

  .tariff-action {
    display: inline-flex;
    justify-content: center;
    min-width: 130px;
    padding: 11px 14px;
    border-radius: 6px;
    background: var(--forest);
    color: #fff;
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .audience-grid,
    .tariff-layout {
      grid-template-columns: 1fr;
    }

    .service-row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .service-row ul,
    .tariff-card {
      grid-template-columns: 1fr;
    }

    .tariff-action {
      width: 100%;
    }
  }
</style>
