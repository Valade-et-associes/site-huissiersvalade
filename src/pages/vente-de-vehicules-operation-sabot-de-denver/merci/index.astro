---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Offre envoyée - Valade et associés"
  description="Confirmation d'envoi d'une offre de véhicule à Valade et associés."
  canonical="/vente-de-vehicules-operation-sabot-de-denver/merci/"
>
  <section class="section">
    <div class="wrap narrow">
      <p class="eyebrow">Offre envoyée</p>
      <h1>Merci pour votre offre</h1>
      <p class="lead">Votre offre a été transmise à l'huissier responsable du dossier. L'équipe communiquera avec vous si votre offre est retenue ou si des informations supplémentaires sont nécessaires.</p>
      <div class="actions">
        <a class="button" href="/vente-de-vehicules-operation-sabot-de-denver/">Retour aux véhicules</a>
      </div>
    </div>
  </section>
</BaseLayout>
